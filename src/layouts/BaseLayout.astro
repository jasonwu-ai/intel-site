---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Daily Briefs, Market Signals, and Divergence Alerts for intelligence-driven decision making.',
} = Astro.props;

const siteTitle = title === 'Intel' ? title : (title + ' - Intel');
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Intel" />
  </head>
  <body class="min-h-screen flex flex-col bg-bg-canvas text-text-body antialiased">
    <!-- Header -->
    <header class="border-b border-white/5 bg-bg-surface/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-brand flex items-center justify-center text-white font-bold text-sm">IN</div>
          <span class="text-lg font-semibold text-gray-100 hidden sm:inline">Intel</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          <a href="/brief" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Daily Brief</a>
          <a href="/signals" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Market Signals</a>
          <a href="/alerts" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-gray-200 hover:bg-white/5 transition-colors">Divergence Alerts</a>
        </nav>
        <details class="md:hidden relative">
          <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-white/5">
            <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 w-56 bg-bg-surface border border-white/10 rounded-xl shadow-2xl overflow-hidden z-50">
            <a href="/brief" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Daily Brief</a>
            <a href="/signals" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5 border-b border-white/5">Market Signals</a>
            <a href="/alerts" class="block px-4 py-3 text-sm text-gray-400 hover:text-gray-200 hover:bg-white/5">Divergence Alerts</a>
          </div>
        </details>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-bg-surface mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <div class="w-6 h-6 rounded bg-brand/20 flex items-center justify-center text-brand text-xs font-bold">IN</div>
          <span>Intel &copy; {new Date().getFullYear()}</span>
        </div>
        <nav class="flex items-center gap-6 text-sm text-gray-500">
          <a href="/brief" class="hover:text-gray-300 transition-colors">Daily Brief</a>
          <a href="/signals" class="hover:text-gray-300 transition-colors">Market Signals</a>
          <a href="/alerts" class="hover:text-gray-300 transition-colors">Divergence Alerts</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
