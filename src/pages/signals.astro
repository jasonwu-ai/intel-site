---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadMarketMovers } from '../lib/data';

const movers = await loadMarketMovers();

// Join topGeoMarkets with shifts.geoRelevant to get delta per market
const shiftsById = new Map(
  (movers?.shifts.geoRelevant || []).map(s => [s.market_id, s])
);

const signals = (movers?.topGeoMarkets || [])
  .map(m => ({
    ...m,
    delta: shiftsById.get(m.market_id)?.delta ?? 0,
  }))
  .sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta))
  .slice(0, 10);
---

<BaseLayout title="Market Signals" description="Real-time indicators and anomaly detection across prediction markets and alternative data.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <span class="text-sm font-medium text-brand mb-2 block">Market Signals</span>
      <h1 class="text-4xl font-bold text-gray-100 mb-4">Signal Dashboard</h1>
      {movers && (
        <p class="text-gray-500 text-sm">Last updated: {movers.generatedAt}</p>
      )}
    </div>

    {signals.length > 0 ? (
      <div class="space-y-6">
        <section class="p-6 bg-bg-surface border border-white/5 rounded-xl">
          <h2 class="text-xl font-semibold text-gray-100 mb-4">Top Geopolitical Markets</h2>
          <div class="space-y-3">
            {signals.map((market) => {
              const positive = market.delta >= 0;
              const deltaColor = positive ? 'text-emerald-400' : 'text-red-400';
              const arrow = positive ? '▲' : '▼';
              return (
                <a 
                  href={`https://sigint.zi.tools/markets/${market.market_id}`}
                  target="_blank"
                  rel="noopener"
                  class="block p-4 bg-bg-canvas rounded-lg border border-white/5 hover:border-brand/30 transition-colors"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1 min-w-0">
                      <p class="text-gray-200 font-medium truncate">{market.question}</p>
                      <p class="text-gray-500 text-sm mt-1">
                        Volume: ${(market.volume / 1e6).toFixed(2)}M · Ends: {market.end_date.split('T')[0]}
                      </p>
                    </div>
                    <div class="text-right space-y-1">
                      <div class={`text-2xl font-bold ${market.yes_probability >= 50 ? 'text-red-400' : 'text-emerald-400'}`}>
                        {market.yes_probability.toFixed(1)}%
                      </div>
                      <div class={`text-sm font-medium ${deltaColor}`}>
                        {arrow} {Math.abs(market.delta).toFixed(2)}%
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      </div>
    ) : (
      <div class="p-6 bg-bg-surface border border-white/5 rounded-xl text-gray-400">
        <p>Market data unavailable.</p>
      </div>
    )}
  </div>
</BaseLayout>
