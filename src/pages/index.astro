---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Intel" description="Daily Briefs, Market Signals, and Divergence Alerts for intelligence-driven decision making.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <!-- Hero -->
    <div class="text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand/10 border border-brand/20 text-brand text-sm font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-brand animate-pulse"></span>
        Live Intelligence Feed
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold text-gray-100 tracking-tight mb-6">
        Intelligence Analysis<br /><span class="text-brand">At Scale</span>
      </h1>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        Daily briefs, market signals, and divergence alerts — synthesized from global data streams for forward-looking decision makers.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/brief" class="px-6 py-3 bg-brand hover:bg-brand-hover text-white font-semibold rounded-lg transition-colors">
          Read the Daily Brief
        </a>
        <a href="/signals" class="px-6 py-3 border border-white/10 hover:border-white/20 text-gray-300 font-semibold rounded-lg transition-colors">
          View Market Signals
        </a>
      </div>
    </div>

    <!-- Feature Cards -->
    <div class="mt-24 grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/brief" class="group p-6 bg-bg-surface border border-white/5 rounded-xl hover:border-brand/30 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-brand transition-colors">Daily Brief</h2>
        <p class="text-sm text-gray-400">Curated intelligence summaries with key events, narratives, and market-moving developments.</p>
      </a>

      <a href="/signals" class="group p-6 bg-bg-surface border border-white/5 rounded-xl hover:border-brand/30 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-brand transition-colors">Market Signals</h2>
        <p class="text-sm text-gray-400">Real-time indicators and anomaly detection across prediction markets and alternative data.</p>
      </a>

      <a href="/alerts" class="group p-6 bg-bg-surface border border-white/5 rounded-xl hover:border-brand/30 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-brand transition-colors">Divergence Alerts</h2>
        <p class="text-sm text-gray-400">Automated alerts when market prices diverge from underlying fundamentals or consensus estimates.</p>
      </a>
    </div>
  </div>
</BaseLayout>
