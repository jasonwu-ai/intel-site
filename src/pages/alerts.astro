---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadMarketMovers } from '../lib/data';

const movers = await loadMarketMovers();

// Use shifts.geoRelevant directly — these are geo-political markets with price changes
// Divergence score = |delta| (absolute change magnitude, higher = more divergence)
const geoShifts = movers?.shifts.geoRelevant || [];

const alerts = [...geoShifts]
  .sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta))
  .slice(0, 8)
  .map(shift => {
    // Divergence score: 0-100 scale based on |delta|, capped at 100
    const divergenceScore = Math.min(Math.abs(shift.delta) * 10, 100);
    const direction = shift.delta >= 0 ? 'upward' : 'downward';
    const briefDesc = `Price moved ${direction} from ${shift.old_price.toFixed(1)}¢ to ${shift.new_price.toFixed(1)}¢`;
    return {
      ...shift,
      divergenceScore,
      briefDesc,
    };
  });
---

<BaseLayout title="Divergence Alerts" description="Automated alerts when market prices diverge from underlying fundamentals or consensus estimates.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <span class="text-sm font-medium text-brand mb-2 block">Divergence Alerts</span>
      <h1 class="text-4xl font-bold text-gray-100 mb-4">Alert Feed</h1>
      <p class="text-gray-500">Markets with significant price divergence from recent snapshots.</p>
    </div>

    {alerts.length > 0 ? (
      <div class="space-y-4">
        {alerts.map((alert) => (
          <div class="p-5 bg-bg-surface border border-amber-500/20 rounded-xl">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="px-2 py-0.5 bg-amber-500/20 text-amber-400 text-xs font-medium rounded">
                    Divergence Signal
                  </span>
                  <span class="px-2 py-0.5 bg-amber-500/10 text-amber-300 text-xs font-medium rounded">
                    Score: {alert.divergenceScore.toFixed(0)}/100
                  </span>
                  <span class="text-gray-500 text-xs">
                    Vol: ${(alert.volume / 1e6).toFixed(2)}M
                  </span>
                </div>
                <p class="text-gray-200 font-medium mb-1">{alert.question}</p>
                <p class="text-gray-400 text-sm mb-3">{alert.briefDesc}</p>
                <a 
                  href={`https://sigint.zi.tools/markets/${alert.market_id}`}
                  target="_blank"
                  rel="noopener"
                  class="text-brand hover:text-brand/80 text-sm"
                >
                  View in Wiki →
                </a>
              </div>
              <div class={`text-right px-3 py-2 rounded-lg ${alert.new_price >= 50 ? 'bg-red-500/10' : 'bg-emerald-500/10'}`}>
                <div class={`text-2xl font-bold ${alert.new_price >= 50 ? 'text-red-400' : 'text-emerald-400'}`}>
                  {alert.new_price.toFixed(1)}¢
                </div>
                <div class={`text-sm font-medium mt-1 ${alert.delta >= 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                  {alert.delta >= 0 ? '▲' : '▼'} {Math.abs(alert.delta).toFixed(2)}%
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-6 bg-bg-surface border border-white/5 rounded-xl text-gray-400">
        <p>No alerts at this time.</p>
      </div>
    )}
  </div>
</BaseLayout>
