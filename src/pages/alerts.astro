---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadMarketMovers } from '../lib/data';

// Divergence alerts: markets where probability seems misaligned
// For now, show high-volume markets as "alerts" since we don't have 
// a separate divergence data source
const movers = await loadMarketMovers();

// Calculate some basic divergence signals
const alerts = movers?.topGeoMarkets
  .filter(m => m.volume > 1e6) // High volume = more divergent pricing possible
  .slice(0, 8) || [];
---

<BaseLayout title="Divergence Alerts" description="Automated alerts when market prices diverge from underlying fundamentals or consensus estimates.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <span class="text-sm font-medium text-brand mb-2 block">Divergence Alerts</span>
      <h1 class="text-4xl font-bold text-gray-100 mb-4">Alert Feed</h1>
      <p class="text-gray-500">Markets with significant volume indicating potential divergence from consensus.</p>
    </div>

    {alerts.length > 0 ? (
      <div class="space-y-4">
        {alerts.map((market) => (
          <div class="p-5 bg-bg-surface border border-amber-500/20 rounded-xl">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 bg-amber-500/20 text-amber-400 text-xs font-medium rounded">
                    Divergence Signal
                  </span>
                  <span class="text-gray-500 text-xs">
                    Vol: ${(market.volume / 1e6).toFixed(2)}M
                  </span>
                </div>
                <p class="text-gray-200 font-medium mb-2">{market.question}</p>
                <a 
                  href={`https://sigint.zi.tools/markets/${market.market_id}`}
                  target="_blank"
                  rel="noopener"
                  class="text-brand hover:text-brand/80 text-sm"
                >
                  View in Wiki →
                </a>
              </div>
              <div class={`text-right px-3 py-2 rounded-lg ${market.yes_probability >= 50 ? 'bg-red-500/10' : 'bg-emerald-500/10'}`}>
                <div class={`text-2xl font-bold ${market.yes_probability >= 50 ? 'text-red-400' : 'text-emerald-400'}`}>
                  {market.yes_probability.toFixed(1)}%
                </div>
                <div class="text-gray-500 text-xs">YES</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-6 bg-bg-surface border border-white/5 rounded-xl text-gray-400">
        <p>No alerts at this time.</p>
      </div>
    )}
  </div>
</BaseLayout>
