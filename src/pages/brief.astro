---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Daily Brief" description="Curated intelligence summaries with key events, narratives, and market-moving developments.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <span class="text-sm font-medium text-brand mb-2 block">Daily Brief</span>
      <h1 class="text-4xl font-bold text-gray-100 mb-4">Intelligence Briefing</h1>
      <p class="text-gray-400">Placeholder — Daily Brief content coming soon.</p>
    </div>
    <div class="prose prose-invert prose-lg max-w-none">
      <div class="p-6 bg-bg-surface border border-white/5 rounded-xl text-gray-400">
        <p>This page is under construction. The Daily Brief will contain curated summaries of key geopolitical events, market-moving developments, and narrative analysis.</p>
      </div>
    </div>
  </div>
</BaseLayout>
